<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Production: only HTTPS to trusted domains -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">gighala.up.railway.app</domain>
        <domain includeSubdomains="true">gighala.com</domain>
        <domain includeSubdomains="true">stripe.com</domain>
        <domain includeSubdomains="true">accounts.google.com</domain>
    </domain-config>

    <!-- Development: allow localhost cleartext for emulator testing -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
